# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ─── Servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── IA (al menos una requerida para los agentes) ────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AI_DEFAULT_MODEL=claude-opus-4-6

# ─── ManyChat (canal WA + Instagram hasta tener verificación Meta) ─
MANYCHAT_API_KEY=
MANYCHAT_WEBHOOK_SECRET=

# ─── Meta Ads (solo lectura de métricas, sin mensajería directa) ───
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=act_XXXXXXXXX
META_APP_SECRET=

# ─── Google Ads ──────────────────────────────────────────────
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# ─── Calendario ──────────────────────────────────────────────
CALENDAR_PROVIDER=calendly
CALENDLY_TOKEN=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
